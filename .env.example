# Copy this file to `.env` and fill in your values.
# The API key is read only by the Vite dev server (see vite.config.ts) and is
# injected into proxied requests — it is NEVER exposed to the browser.
AI_API_KEY=sk-your-key-here

# Which model the app asks the LiteLLM proxy to use. This one IS visible to the
# browser (it goes in the request body), so it must be prefixed with VITE_.
VITE_AI_MODEL=gpt-4o-mini
